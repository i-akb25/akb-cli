# ==========================================
# AKB CLI
# Python .gitignore
# ==========================================

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Compiled extensions
*.so
*.pyd
*.pyo

# Distribution / Packaging
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# Virtual Environments
venv/
.venv/
env/
ENV/

# IDEs
.vscode/
.idea/
*.code-workspace

# Operating System Files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log

# Environment Variables
.env
.env.*

# Python Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type Checkers
.mypy_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/

# Temporary Files
*.tmp
*.temp
*.bak
*.swp
*.swo

# macOS
.AppleDouble
.LSOverride

# Linux
*~

# Project Specific
.history/